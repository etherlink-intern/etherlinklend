# Public Etherlink RPC. Override in your local .env with a dedicated endpoint;
# public RPCs are rate-limited and not suitable for production bots/keepers/liquidators.
ETHERLINK_MAINNET_RPC_URL=https://node.mainnet.etherlink.com
ETHERLINK_SHADOWNET_RPC_URL=https://node.shadownet.etherlink.com
PRIVATE_KEY=
DEPLOYER_ADDRESS=
# Etherlink explorers are Blockscout. `forge verify-contract --verifier blockscout` needs no key;
# this var is kept only for tooling that expects it to exist.
ETHERSCAN_API_KEY=YOU_CAN_COPY_ME
PYTH_CONTRACT_ADDRESS=
REDSTONE_ADAPTER_ADDRESS=
DEFAULT_BROADCASTER=
CONFIRM_DEPLOYMENT=false
